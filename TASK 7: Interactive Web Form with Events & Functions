PROGRAM IN HTML:
<!DOCTYPE html>
<html>
<head>
<title>Interactive Feedback Form</title>

<style>
body {
    font-family: Arial;
    background: #f4f6f9;
}

.container {
    width: 400px;
    margin: 60px auto;
    background: white;
    padding: 25px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}

h2 {
    text-align: center;
}

input, textarea, select {
    width: 100%;
    padding: 8px;
    margin-top: 8px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 5px;
    transition: 0.3s;
}

input:hover, textarea:hover, select:hover {
    background-color: #e6f2ff;
}

button {
    width: 100%;
    padding: 10px;
    background: #007bff;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

button:hover {
    background: #0056b3;
}

.error {
    color: red;
    font-size: 12px;
}
</style>

<script>
// Reusable validation function
function validateField(id, errorId, message) {
    var value = document.getElementById(id).value;
    if (value.trim() === "") {
        document.getElementById(errorId).innerHTML = message;
        return false;
    } else {
        document.getElementById(errorId).innerHTML = "";
        return true;
    }
}

// Email validation
function validateEmail() {
    var email = document.getElementById("email").value;
    var pattern = /^[^ ]+@[^ ]+\.[a-z]{2,3}$/;
    if (!pattern.test(email)) {
        document.getElementById("emailError").innerHTML = "Invalid Email Format";
        return false;
    } else {
        document.getElementById("emailError").innerHTML = "";
        return true;
    }
}

// Confirmation on double click submit
function confirmSubmit() {
    if (
        validateField("name", "nameError", "Name is required") &&
        validateField("feedback", "feedbackError", "Feedback is required") &&
        validateEmail()
    ) {
        alert("Feedback Submitted Successfully!");
        document.getElementById("feedbackForm").reset();
    } else {
        alert("Please fix errors before submitting.");
    }
}
</script>

</head>

<body>

<div class="container">
    <h2>Customer Feedback Form</h2>

    <form id="feedbackForm">

        <label>Name:</label>
        <input type="text" id="name" onkeyup="validateField('name','nameError','Name is required')">
        <div id="nameError" class="error"></div>

        <label>Email:</label>
        <input type="text" id="email" onkeyup="validateEmail()">
        <div id="emailError" class="error"></div>

        <label>Rating:</label>
        <select id="rating">
            <option value="">Select Rating</option>
            <option>Excellent</option>
            <option>Good</option>
            <option>Average</option>
            <option>Poor</option>
        </select>

        <label>Feedback:</label>
        <textarea id="feedback" rows="4"
        onkeyup="validateField('feedback','feedbackError','Feedback is required')"></textarea>
        <div id="feedbackError" class="error"></div>

        <button type="button" ondblclick="confirmSubmit()">
            Double Click to Submit
        </button>

    </form>
</div>

</body>
</html>
